{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "UrLang",
  "scopeName": "source.urlang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#jsx" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#function-declaration" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "jsx": {
      "comment": "JSX elements in .urx files: <div a={x}>...</div>, <Comp/>, fragments.",
      "patterns": [
        {
          "comment": "Opening/self-closing tag. The lookbehind keeps generics (kaam f<T>) from reading as tags.",
          "begin": "(?<![A-Za-z0-9_$])(<)([A-Za-z_$][-A-Za-z0-9_$.]*)",
          "end": "(/?>)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.urlang" },
            "2": { "name": "entity.name.tag.urlang" }
          },
          "endCaptures": { "1": { "name": "punctuation.definition.tag.end.urlang" } },
          "patterns": [
            {
              "name": "entity.other.attribute-name.urlang",
              "match": "[A-Za-z_$][-A-Za-z0-9_$]*(?=\\s*=|\\s|/|>)"
            },
            { "include": "#strings" },
            {
              "comment": "{expression} inside a tag — full UrLang.",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.urlang" } },
              "endCaptures": { "0": { "name": "punctuation.section.embedded.end.urlang" } },
              "patterns": [{ "include": "$self" }]
            },
            { "name": "keyword.operator.assignment.urlang", "match": "=" }
          ]
        },
        {
          "name": "punctuation.definition.tag.urlang",
          "comment": "Closing tag and fragment delimiters.",
          "match": "(</)([A-Za-z_$][-A-Za-z0-9_$.]*)?(>)|(<>)"
        },
        {
          "comment": "{expression} between tags.",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.urlang" } },
          "endCaptures": { "0": { "name": "punctuation.section.embedded.end.urlang" } },
          "patterns": [{ "include": "$self" }]
        }
      ]
    },
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.urlang", "match": "//.*$" },
        { "name": "comment.block.urlang", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.urlang",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "name": "constant.character.escape.urlang", "match": "\\\\." }]
        },
        {
          "name": "string.quoted.single.urlang",
          "begin": "'",
          "end": "'",
          "patterns": [{ "name": "constant.character.escape.urlang", "match": "\\\\." }]
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.urlang",
      "match": "\\b(0[xX][0-9a-fA-F_]+|0[bB][01_]+|0[oO][0-7_]+|[0-9][0-9_]*(\\.[0-9_]+)?)\\b"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.urlang",
          "match": "\\b(agar|warna|jab|tak|bas|agla|wapas|har|mein|koshish|pakro|akhir|phenko|intezar|chuno|surat|karo)\\b"
        },
        {
          "name": "storage.type.urlang",
          "match": "\\b(rakho|pakka|kaam|qisim|jamaat|waris|fehrist)\\b"
        },
        {
          "name": "storage.modifier.urlang",
          "match": "\\b(sakit|nijee|hasil|lagao)\\b"
        },
        {
          "name": "keyword.operator.word.urlang",
          "match": "\\b(noeyat|hai|andar|mitao|jaisa)\\b"
        },
        {
          "name": "keyword.other.urlang",
          "match": "\\b(bolo|bhejo|lao|se|bahar|asal|sab|naya|buzurg)\\b"
        },
        {
          "name": "variable.language.urlang",
          "match": "\\b(yeh)\\b"
        }
      ]
    },
    "types": {
      "name": "support.type.urlang",
      "match": "\\b(adad|lafz|bool|koi|khaali|kuchnahi|Wada)\\b"
    },
    "constants": {
      "name": "constant.language.urlang",
      "match": "\\b(sach|jhoot|khaali)\\b"
    },
    "function-declaration": {
      "match": "\\b(kaam)\\s+([A-Za-z_$][A-Za-z0-9_$]*)",
      "captures": {
        "1": { "name": "storage.type.urlang" },
        "2": { "name": "entity.name.function.urlang" }
      }
    },
    "function-call": {
      "match": "\\b([A-Za-z_$][A-Za-z0-9_$]*)\\s*(?=\\()",
      "name": "entity.name.function.urlang"
    },
    "operators": {
      "name": "keyword.operator.urlang",
      "match": "(==|!=|<=|>=|&&|\\|\\||[+\\-*/%=<>!])"
    }
  }
}
