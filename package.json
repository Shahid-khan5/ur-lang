{
  "name": "ur-lang",
  "version": "1.4.0",
  "description": "UrLang — an Urdu-flavored, statically type-checked language that compiles to JavaScript, with JSX/React support. Works everywhere JS works: Node, browsers, Electron, Tauri.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "urlang": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./vite": "./dist/vite-plugin.js",
    "./bun": "./dist/bun-plugin.js",
    "./dts": "./dist/dts.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SPEC.md",
    "docs"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.build.json",
    "bench": "tsx bench/bench.ts",
    "playground:build": "esbuild src/index.ts --bundle --format=esm --outfile=playground/compiler.js --minify"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shahid-khan5/ur-lang.git"
  },
  "homepage": "https://github.com/Shahid-khan5/ur-lang#readme",
  "bugs": {
    "url": "https://github.com/Shahid-khan5/ur-lang/issues"
  },
  "keywords": [
    "urdu",
    "language",
    "compiler",
    "transpiler",
    "typed",
    "jsx",
    "react",
    "vite-plugin",
    "tauri",
    "electron",
    "bhailang"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bun": "^1.3.14",
    "esbuild": "^0.25.0",
    "express": "^5.2.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "svelte": "^5.56.4",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  },
  "optionalDependencies": {
    "typescript": "^5.9.3"
  }
}
